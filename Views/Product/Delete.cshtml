@model Webbanhang.Models.Product
@{ ViewData["Title"] = "Xóa sản phẩm"; }
<div class="container py-5"><div class="delete-card mx-auto"><div class="delete-icon">⚠️</div><h1 class="fw-bold mt-3">Xóa sản phẩm?</h1><p>Bạn có chắc chắn muốn xóa <strong>@Model.Name</strong> khỏi cửa hàng không?</p><div class="d-flex gap-3 align-items-center product-delete-preview"><img src="@(string.IsNullOrEmpty(Model.ImageUrl) ? Url.Content("~/images/khay-thap-cam.jpg") : Model.ImageUrl)" alt="@Model.Name" /><div><h5 class="fw-bold">@Model.Name</h5><p class="mb-1">Danh mục: @(Model.Category?.Name ?? "Chưa phân loại")</p><strong class="price">@Model.Price.ToString("N0") VNĐ</strong></div></div><form asp-action="DeleteConfirmed" method="post" class="d-flex gap-2 justify-content-center mt-4 flex-wrap">@Html.AntiForgeryToken()<input type="hidden" asp-for="Id" /><button type="submit" class="btn btn-danger px-4">Xác nhận xóa</button><a asp-action="Index" class="btn btn-outline-secondary px-4">Hủy</a></form></div></div>

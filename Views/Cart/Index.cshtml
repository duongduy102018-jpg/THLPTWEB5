@model Webbanhang.Models.CartSummaryViewModel
@{ ViewData["Title"] = "Giỏ hàng"; }
<section class="page-hero"><div class="container position-relative"><span class="hero-badge">🛒 Giỏ hàng</span><h1 class="fw-bold mt-3 display-5">Kiểm tra đơn trước khi thanh toán</h1><p>Điều chỉnh số lượng, áp mã giảm giá và xem phí giao hàng trước khi đặt hàng.</p></div></section>
<div class="container py-5">
    @if (!Model.Items.Any())
    {
        <div class="empty-state"><div class="empty-icon">🛒</div><h3>Giỏ hàng đang trống</h3><p>Hãy chọn một vài sản phẩm trái cây tươi cho đơn hàng của bạn.</p><a asp-controller="Product" asp-action="Index" class="btn btn-success px-4">Xem sản phẩm</a></div>
    }
    else
    {
        <div class="row g-4">
            <div class="col-lg-8">
                <div class="d-flex justify-content-between align-items-center mb-3 flex-wrap gap-2"><h3 class="fw-bold mb-0">Sản phẩm đã chọn</h3><a asp-controller="Product" asp-action="Index" class="btn btn-outline-success px-4">Tiếp tục mua</a></div>
                <div class="cart-list">
                    @foreach (var item in Model.Items)
                    {
                        <div class="cart-item">
                            <img src="@(string.IsNullOrEmpty(item.ImageUrl) ? Url.Content("~/images/khay-thap-cam.jpg") : item.ImageUrl)" alt="@item.ProductName" />
                            <div class="cart-info"><h5>@item.ProductName</h5><p>@item.Price.ToString("N0") VNĐ / sản phẩm</p></div>
                            <form asp-action="UpdateQuantity" method="post" class="quantity-form"><input type="hidden" name="id" value="@item.ProductId" /><input type="number" name="quantity" value="@item.Quantity" min="0" class="form-control" /><button class="btn btn-outline-success btn-sm">Cập nhật</button></form>
                            <strong class="price">@item.Total.ToString("N0") VNĐ</strong>
                            <form asp-action="Remove" method="post"><input type="hidden" name="id" value="@item.ProductId" /><button class="btn btn-link text-danger fw-bold">Xóa</button></form>
                        </div>
                    }
                </div>
            </div>
            <div class="col-lg-4">
                <div class="cart-summary">
                    <h4>Tóm tắt đơn hàng</h4>
                    <form asp-action="ApplyCoupon" method="post" class="coupon-box mb-3">@Html.AntiForgeryToken()<label class="form-label">Mã giảm giá</label><div class="input-group"><input name="couponCode" value="@Model.CouponCode" class="form-control" placeholder="FRESH10 / COMBO50" /><button class="btn btn-success">Áp dụng</button></div></form>
                    @if (!string.IsNullOrWhiteSpace(Model.CouponCode)) { <form asp-action="RemoveCoupon" method="post" class="mb-3">@Html.AntiForgeryToken()<button class="btn btn-outline-danger btn-sm">Bỏ mã @Model.CouponCode</button></form> }
                    <div class="summary-row"><span>Tạm tính</span><strong>@Model.Subtotal.ToString("N0") VNĐ</strong></div>
                    <div class="summary-row"><span>Giảm giá</span><strong>-@Model.Discount.ToString("N0") VNĐ</strong></div>
                    <div class="summary-row"><span>Phí giao hàng</span><strong>@(Model.FreeShipping ? "Miễn phí" : Model.ShippingFee.ToString("N0") + " VNĐ")</strong></div>
                    <div class="free-ship-note">Miễn phí giao hàng cho đơn từ 500.000 VNĐ.</div><hr />
                    <div class="summary-row total"><span>Tổng cộng</span><strong>@Model.GrandTotal.ToString("N0") VNĐ</strong></div>
                    <a asp-action="Checkout" class="btn btn-success btn-lg w-100 mt-3">Tiến hành đặt hàng</a>
                    <form asp-action="Clear" method="post" class="mt-2"><button class="btn btn-outline-danger w-100">Xóa giỏ hàng</button></form>
                </div>
            </div>
        </div>
    }
</div>
